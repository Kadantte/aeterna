# Yerel geliştirme şablonu — kopyalayın: cp .env.example .env
# Backend: set -a && source .env && set +a && cd backend && go run ./cmd/server --encryption-key-file=../secrets/encryption_key

ENV=development
DATABASE_PATH=./data/aeterna.db
DB_ENCRYPTION_ENABLED=false
DB_ENCRYPTION_AUTO_MIGRATE=true
# Fixed path expected by install.sh and backend runtime.
DB_ENCRYPTION_KDF_CONTEXT_FILE=./secrets/db_kdf_context
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BASE_URL=http://localhost:5173
AUTH_SESSION_TTL_HOURS=12
LOG_LEVEL=info

# İsteğe bağlı — ek kullanıcı kaydı: ortam değişkeni VEYA Ayarlar’da ilk (birincil) yöneticinin açtığı “Allow registration”
# ALLOW_REGISTRATION=true
# MASTER_PASSWORD=
# WEBHOOK_ALLOWLIST_HOSTS=
# LOG_FORMAT=json
# LOG_FILE=
